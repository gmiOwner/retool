<GlobalFunctions>
  <State
    id="selectedBacklog"
    value={
      '{\n  "epics": [\n    {\n      "title": "Supply Chain Data Ingestion & Integration",\n      "description": "Establish reliable, governed data pipelines to ingest internal and external demand/supply signals (e.g., POS, shipments, promotions, seasonality, external data) and integrate outputs with ERP (SAP). This epic ensures timely refreshes, scalability for multi-year history, and data quality controls required for forecasting and inventory optimization.",\n      "features": [\n        {\n          "title": "Multi-source data ingestion (internal & external)",\n          "description": "Ingest structured and unstructured data daily (hourly preferred) from POS, shipment history, promotions, seasonality indicators, and external sources to support downstream forecasting and planning.",\n          "userStories": [\n            {\n              "title": "Ingest POS and shipment history data on a schedule",\n              "description": "As a data engineer,\\nI want to ingest POS and shipment history data on a scheduled cadence,\\nso that forecasting models always use up-to-date demand signals.",\n              "acceptanceCriteria": [\n                "Given POS and shipment source connections are configured When the scheduled ingestion runs Then new and changed records are loaded successfully and a completion status is recorded",\n                "Given an ingestion run fails When the system detects the failure Then an error is logged and an alert is generated for support",\n                "Given the ingestion has completed When a user checks the last refresh timestamp Then the timestamp reflects the latest successful load"\n              ],\n              "tasks": [\n                {\n                  "title": "Define POS and shipment data mappings",\n                  "description": "Document required fields, grain, and transformations for POS and shipment history sources."\n                },\n                {\n                  "title": "Configure scheduled ingestion cadence",\n                  "description": "Set up daily ingestion schedule and parameterize for hourly runs where feasible."\n                },\n                {\n                  "title": "Implement ingestion logging and run-status tracking",\n                  "description": "Capture start/end time, record counts, and success/failure status per run."\n                },\n                {\n                  "title": "Set up failure alerting",\n                  "description": "Configure notifications for failed runs to the designated support group."\n                },\n                {\n                  "title": "Validate loaded data completeness",\n                  "description": "Run post-load checks for expected volumes and key field presence."\n                }\n              ],\n              "traceability": [\n                {\n                  "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n                  "evidenceSnippet": "Data Ingestion: Collect POS data, shipment history... System shall ingest structured and unstructured data... daily."\n                }\n              ]\n            },\n            {\n              "title": "Ingest promotions, seasonality, and external data",\n              "description": "As a demand planner,\\nI want promotion schedules, seasonality indicators, and external signals ingested into the platform,\\nso that baseline forecasts reflect known demand drivers.",\n              "acceptanceCriteria": [\n                "Given promotion and seasonality sources are configured When ingestion runs Then the data is available for the relevant products/locations and time periods",\n                "Given external data is missing for a period When a forecast is generated Then the system flags the missing input and proceeds with documented fallback behavior",\n                "Given ingested driver data When a planner views model inputs Then promotions/seasonality/external signals are visible and time-aligned"\n              ],\n              "tasks": [\n                {\n                  "title": "Identify required driver datasets",\n                  "description": "Confirm promotion, seasonality, and external sources and required attributes/time granularity."\n                },\n                {\n                  "title": "Create transformations for time alignment",\n                  "description": "Align driver data to the forecast calendar (e.g., week/month) and product/location hierarchy."\n                },\n                {\n                  "title": "Implement missing-data detection",\n                  "description": "Add checks to flag gaps and late-arriving driver data."\n                },\n                {\n                  "title": "Expose driver data to forecasting inputs",\n                  "description": "Ensure forecasting workflows can reference ingested driver tables/feeds."\n                }\n              ],\n              "traceability": [\n                {\n                  "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n                  "evidenceSnippet": "Data Ingestion: Collect ... promotion schedules, seasonality indicators, and external data."\n                }\n              ]\n            },\n            {\n              "title": "Automated data validation checks",\n              "description": "As a supply chain analytics product owner,\\nI want automated data validation checks,\\nso that poor data quality is detected early and does not degrade forecast accuracy.",\n              "acceptanceCriteria": [\n                "Given a dataset is ingested When validation rules execute Then anomalies (null spikes, duplicates, outliers) are detected and recorded",\n                "Given a critical validation fails When the pipeline completes Then the run is marked with a quality warning/blocker according to severity",\n                "Given validation results When support reviews the dashboard/log Then they can see which rules failed and recommended actions"\n              ],\n              "tasks": [\n                {\n                  "title": "Define data quality rule set",\n                  "description": "Create validation rules for completeness, uniqueness, timeliness, and reasonableness for each source."\n                },\n                {\n                  "title": "Implement validation execution post-ingestion",\n                  "description": "Run validation after each ingestion and persist results."\n                },\n                {\n                  "title": "Configure severity thresholds and actions",\n                  "description": "Set severity levels and whether to warn, block, or allow processing with flags."\n                },\n                {\n                  "title": "Create validation results view",\n                  "description": "Provide an accessible report/log of validation outcomes for operations."\n                }\n              ],\n              "traceability": [\n                {\n                  "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n                  "evidenceSnippet": "Poor data quality → Implement automated data validation checks."\n                }\n              ]\n            }\n          ],\n          "traceability": [\n            {\n              "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n              "evidenceSnippet": "System shall ingest structured and unstructured data... Data refresh frequency: Daily minimum; hourly preferred."\n            }\n          ]\n        },\n        {\n          "title": "ERP (SAP) integration for planning inputs/outputs",\n          "description": "Integrate with SAP ERP to both consume required master/transactional data and publish forecast and inventory optimization outputs for production and replenishment planning.",\n          "userStories": [\n            {\n              "title": "Sync forecast outputs to ERP for production planning",\n              "description": "As a supply planning manager,\\nI want approved forecast outputs synchronized to SAP,\\nso that production planning uses the latest consensus demand signal.",\n              "acceptanceCriteria": [\n                "Given a forecast is approved When the sync job runs Then forecast quantities are transmitted to SAP for the defined horizon and planning level",\n                "Given SAP is unavailable When synchronization is attempted Then the job retries per policy and records the failure for support follow-up",\n                "Given a successful sync When a planner audits the interface log Then the transmitted quantities and timestamps are traceable"\n              ],\n              "tasks": [\n                {\n                  "title": "Define SAP interface scope for forecasts",\n                  "description": "Confirm objects, planning level (SKU/location), horizon, and format required by SAP."\n                },\n                {\n                  "title": "Design and document interface mapping",\n                  "description": "Map internal forecast outputs to SAP inbound structures."\n                },\n                {\n                  "title": "Implement interface logging and audit trail",\n                  "description": "Persist what was sent, when, and by which process/user."\n                },\n                {\n                  "title": "Set up retry and failure handling",\n                  "description": "Configure retries and escalation path for interface failures."\n                }\n              ],\n              "traceability": [\n                {\n                  "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n                  "evidenceSnippet": "Integration with ERP (SAP)... Supply Planning Integration: Sync outputs with ERP for production planning."\n                }\n              ]\n            },\n            {\n              "title": "Sync inventory policy outputs (safety stock/reorder points) to ERP",\n              "description": "As a replenishment planner,\\nI want safety stock and reorder point recommendations published to SAP,\\nso that replenishment parameters reflect optimized inventory policies.",\n              "acceptanceCriteria": [\n                "Given inventory optimization has produced policy parameters When outputs are approved Then safety stock and reorder points are sent to SAP for the selected items/locations",\n                "Given a user selects a subset for pilot When publishing occurs Then only the selected scope is updated in SAP",\n                "Given publishing completes When audit logs are reviewed Then before/after values and approver are recorded"\n              ],\n              "tasks": [\n                {\n                  "title": "Define ERP fields for inventory policy parameters",\n                  "description": "Identify SAP parameter fields and constraints for safety stock and reorder points."\n                },\n                {\n                  "title": "Create approval gate for publishing",\n                  "description": "Require explicit approval before updating ERP parameters."\n                },\n                {\n                  "title": "Implement selective publish controls",\n                  "description": "Enable publishing by product/location/segment for pilots and phased rollout."\n                },\n                {\n                  "title": "Implement before/after comparison report",\n                  "description": "Provide a report of proposed vs current parameters for review and audit."\n                }\n              ],\n              "traceability": [\n                {\n                  "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n                  "evidenceSnippet": "Inventory optimization logic (safety stock, reorder points)... Supply Planning Integration: Sync outputs with ERP."\n                }\n              ]\n            }\n          ],\n          "traceability": [\n            {\n              "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n              "evidenceSnippet": "Integration with ERP (SAP) and POS data sources."\n            }\n          ]\n        }\n      ],\n      "traceability": [\n        {\n          "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n          "evidenceSnippet": "In Scope: Integration with ERP (SAP) and POS data sources."\n        }\n      ]\n    },\n    {\n      "title": "Demand Forecasting (Baseline + Review/Adjustment)",\n      "description": "Deliver baseline statistical/ML forecasts using multiple model options and enable demand planners to review, adjust, and document overrides. This epic targets improved forecast accuracy and planner productivity through automation and governed workflows.",\n      "features": [\n        {\n          "title": "Baseline forecast generation with multiple models",\n          "description": "Generate baseline forecasts using supported statistical and machine learning approaches and ensure the system can handle long historical series for training and backtesting.",\n          "userStories": [\n            {\n              "title": "Generate a baseline forecast using selectable forecasting models",\n              "description": "As a data scientist,\\nI want the platform to generate baseline forecasts using multiple supported models,\\nso that we can choose the best-performing approach by product/segment.",\n              "acceptanceCriteria": [\n                "Given historical demand data is available When a user selects a model (e.g., ARIMA/Prophet/ML regression) and runs forecasting Then a baseline forecast is produced for the defined horizon",\n                "Given multiple models are run When results are compared Then the system provides forecast accuracy metrics (e.g., MAPE/WAPE) per model and segment",\n                "Given 5+ years of history When a model run is executed Then the run completes within agreed capacity constraints without truncating required history"\n              ],\n              "tasks": [\n                {\n                  "title": "Define supported model catalog",\n                  "description": "List initial models (ARIMA, Prophet, ML regression) and parameter options exposed to users."\n                },\n                {\n                  "title": "Set up forecast run configuration",\n                  "description": "Define forecast horizon, time bucket, segmentation, and model selection inputs."\n                },\n                {\n                  "title": "Implement model run tracking",\n                  "description": "Capture run metadata (model, parameters, data window) and store outputs."\n                },\n                {\n                  "title": "Compute and store accuracy metrics",\n                  "description": "Calculate MAPE/WAPE and persist results for comparison."\n                }\n              ],\n              "traceability": [\n                {\n                  "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n                  "evidenceSnippet": "System shall support multiple forecasting models (ARIMA, Prophet, ML regression, etc.)."\n                }\n              ]\n            },\n            {\n              "title": "Backtest models to reduce overfitting risk",\n              "description": "As a model governance lead,\\nI want regular backtesting of forecasting models,\\nso that overfitting is detected and model performance remains reliable.",\n              "acceptanceCriteria": [\n                "Given a forecast model is configured When backtesting is executed on historical periods Then performance metrics are produced and stored",\n                "Given backtesting indicates degradation When thresholds are breached Then the system flags the model/segment for governance review",\n                "Given governance reviewers access results When they inspect a run Then they can see data windows, parameters, and metrics used"\n              ],\n              "tasks": [\n                {\n                  "title": "Define backtesting methodology",\n                  "description": "Select rolling/expanding window approach and evaluation periods."\n                },\n                {\n                  "title": "Implement scheduled backtesting",\n                  "description": "Configure recurring backtest runs and storage of outputs."\n                },\n                {\n                  "title": "Set performance thresholds",\n                  "description": "Define thresholds that trigger governance review flags."\n                },\n                {\n                  "title": "Create governance review packet output",\n                  "description": "Assemble run metadata, charts, and metrics for review."\n                }\n              ],\n              "traceability": [\n                {\n                  "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n                  "evidenceSnippet": "Model overfitting → Regular backtesting and governance review."\n                }\n              ]\n            }\n          ],\n          "traceability": [\n            {\n              "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n              "evidenceSnippet": "Baseline Forecast Generation: Apply statistical and machine learning models."\n            }\n          ]\n        },\n        {\n          "title": "Planner review, adjustment, and override governance",\n          "description": "Enable demand planners to review baseline forecasts, apply overrides, and document rationale with an auditable trail to improve accountability and collaboration.",\n          "userStories": [\n            {\n              "title": "Review baseline forecast and apply overrides with rationale",\n              "description": "As a demand planner,\\nI want to override baseline forecasts and record the rationale,\\nso that adjustments are transparent and can be reviewed later.",\n              "acceptanceCriteria": [\n                "Given a baseline forecast exists When I enter an override value Then the system requires a rationale note before saving",\n                "Given an override is saved When another user reviews the forecast Then they can see baseline vs overridden values and the rationale",\n                "Given audit logging is enabled When overrides are created/edited Then user, timestamp, and change details are captured"\n              ],\n              "tasks": [\n                {\n                  "title": "Design override capture requirements",\n                  "description": "Define required fields (rationale, category, comments) and validation rules."\n                },\n                {\n                  "title": "Implement baseline vs override comparison view",\n                  "description": "Provide side-by-side display and change deltas for planner review."\n                },\n                {\n                  "title": "Implement audit logging for overrides",\n                  "description": "Record who changed what and when, including rationale text."\n                },\n                {\n                  "title": "Create review workflow states",\n                  "description": "Define statuses such as Draft, Reviewed, Approved for publishing."\n                }\n              ],\n              "traceability": [\n                {\n                  "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n                  "evidenceSnippet": "Users shall be able to override forecasts with documented rationale."\n                }\n              ]\n            },\n            {\n              "title": "Automate planner workflow to improve productivity",\n              "description": "As a supply chain planning leader,\\nI want automation in forecast review workflows,\\nso that planners spend less time on manual steps and more on exception management.",\n              "acceptanceCriteria": [\n                "Given new baseline forecasts are generated When the review cycle starts Then planners are notified and can see assigned scope",\n                "Given low-impact items exist When exception rules are applied Then the system highlights only items requiring attention",\n                "Given the review is complete When approvals are recorded Then outputs are eligible for downstream integration"\n              ],\n              "tasks": [\n                {\n                  "title": "Define planner assignment and scope rules",\n                  "description": "Determine how products/locations are allocated to planners."\n                },\n                {\n                  "title": "Define exception thresholds",\n                  "description": "Set rules to flag items by forecast change, volatility, or KPI impact."\n                },\n                {\n                  "title": "Configure notifications for review cycles",\n                  "description": "Notify planners of new cycles and pending approvals."\n                },\n                {\n                  "title": "Implement readiness checks for publishing",\n                  "description": "Ensure all required reviews/approvals are completed before ERP sync."\n                }\n              ],\n              "traceability": [\n                {\n                  "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n                  "evidenceSnippet": "Increase planner productivity through automation and scenario modeling."\n                }\n              ]\n            }\n          ],\n          "traceability": [\n            {\n              "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n              "evidenceSnippet": "Planner Review & Adjustment: Demand planners review and adjust forecasts."\n            }\n          ]\n        }\n      ],\n      "traceability": [\n        {\n          "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n          "evidenceSnippet": "Statistical baseline forecasting engine... Planner Review & Adjustment... override forecasts with documented rationale."\n        }\n      ]\n    },\n    {\n      "title": "Inventory Optimization & Replenishment Policy",\n      "description": "Calculate optimized inventory parameters (safety stock, reorder points, target inventory) using service level targets and demand variability, with the goal of reducing inventory carrying costs while maintaining or improving service levels and reducing stockouts.",\n      "features": [\n        {\n          "title": "Safety stock, reorder point, and target inventory calculations",\n          "description": "Compute inventory policy parameters based on demand variability and service-level targets, and provide clear recommended settings by item/location.",\n          "userStories": [\n            {\n              "title": "Calculate safety stock from service level targets and demand variability",\n              "description": "As an inventory analyst,\\nI want safety stock calculated using service level targets and demand variability,\\nso that inventory buffers are aligned to desired customer service outcomes.",\n              "acceptanceCriteria": [\n                "Given service level targets are defined for an item/location When the optimization run is executed Then safety stock is calculated and stored",\n                "Given demand variability changes When the next run executes Then safety stock recommendations adjust accordingly and changes are traceable",\n                "Given a user views the results When they inspect an item/location Then the system shows inputs used (target service level, variability measures)"\n              ],\n              "tasks": [\n                {\n                  "title": "Define required inputs for safety stock",\n                  "description": "Identify service level targets, lead time assumptions, and variability metrics needed."\n                },\n                {\n                  "title": "Implement calculation output storage",\n                  "description": "Persist safety stock values with run timestamp and version."\n                },\n                {\n                  "title": "Create explainability fields for inputs",\n                  "description": "Store and display the key inputs used for each recommendation."\n                }\n              ],\n              "traceability": [\n                {\n                  "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n                  "evidenceSnippet": "System shall calculate safety stock based on service level targets and demand variability."\n                }\n              ]\n            },\n            {\n              "title": "Calculate reorder points and target inventory levels",\n              "description": "As a replenishment planner,\\nI want reorder points and target inventory levels calculated,\\nso that ordering decisions reduce stockouts while minimizing excess inventory.",\n              "acceptanceCriteria": [\n                "Given demand and lead time inputs When the optimization run executes Then reorder points and target inventory levels are produced",\n                "Given service level targets are increased When recalculated Then reorder points/targets increase in a predictable and documented way",\n                "Given results are available When exporting or publishing Then values can be selected by scope (product/location/segment)"\n              ],\n              "tasks": [\n                {\n                  "title": "Define parameter calculation rules",\n                  "description": "Confirm formulas/logic for reorder points and target inventory based on inputs."\n                },\n                {\n                  "title": "Implement output versioning",\n                  "description": "Track versions of recommendations per run for audit and comparison."\n                },\n                {\n                  "title": "Implement scoping for publish/export",\n                  "description": "Allow filtering by segment, product, location for operational use."\n                }\n              ],\n              "traceability": [\n                {\n                  "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n                  "evidenceSnippet": "Inventory optimization logic (safety stock, reorder points)... target inventory levels."\n                }\n              ]\n            }\n          ],\n          "traceability": [\n            {\n              "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n              "evidenceSnippet": "Inventory Optimization Calculation: Determine safety stock, reorder points, and target inventory levels."\n            }\n          ]\n        },\n        {\n          "title": "Service level policy management",\n          "description": "Manage and maintain service level targets used as key inputs to inventory optimization, enabling differentiated policies across products, customers, or channels.",\n          "userStories": [\n            {\n              "title": "Maintain service level targets by segment",\n              "description": "As a supply chain manager,\\nI want to define and maintain service level targets by product/channel segment,\\nso that inventory optimization aligns with business priorities.",\n              "acceptanceCriteria": [\n                "Given I have permission to edit policies When I set a service level target for a segment Then the target is saved and effective-dated",\n                "Given a target changes When the next optimization run occurs Then the new target is used for calculations",\n                "Given an auditor reviews policy changes When they view policy history Then they can see who changed what and when"\n              ],\n              "tasks": [\n                {\n                  "title": "Define segmentation scheme for service levels",\n                  "description": "Identify how service level targets vary (e.g., ABC class, channel, region)."\n                },\n                {\n                  "title": "Implement effective-dated policy storage",\n                  "description": "Store current and historical policy values with validity periods."\n                },\n                {\n                  "title": "Enable audit trail for policy edits",\n                  "description": "Log user, timestamp, and old/new target values."\n                }\n              ],\n              "traceability": [\n                {\n                  "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n                  "evidenceSnippet": "System shall calculate safety stock based on service level targets..."\n                }\n              ]\n            }\n          ],\n          "traceability": [\n            {\n              "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n              "evidenceSnippet": "Reduce finished goods inventory by 8-12% while maintaining service levels. Decrease stockout incidents by 15%."\n            }\n          ]\n        },\n        {\n          "title": "Scenario Planning & Simulation",\n          "description": "Provide scenario modeling and simulation capabilities so planners and leaders can evaluate impacts of demand surges, supply disruptions, promotions, and policy changes on forecasts, inventory, service levels, and working capital.",\n          "features": [\n            {\n              "title": "Scenario definition and what-if simulation",\n              "description": "Allow users to create and run scenarios (e.g., demand surge, supply disruption) and compare projected KPIs against baseline.",\n              "userStories": [\n                {\n                  "title": "Create a demand surge scenario and simulate impacts",\n                  "description": "As a demand planner,\\nI want to simulate a demand surge scenario,\\nso that I can understand impacts to inventory, service level, and stockout risk before committing to a plan.",\n                  "acceptanceCriteria": [\n                    "Given a baseline forecast exists When I define a demand uplift by % or units for a time period Then a scenario forecast is generated",\n                    "Given the scenario forecast is generated When I run simulation Then projected inventory and service-level impacts are calculated",\n                    "Given baseline and scenario results When I compare them Then the system shows deltas for key KPIs (service level, stockout rate, DOH, working capital)"\n                  ],\n                  "tasks": [\n                    {\n                      "title": "Define scenario input options",\n                      "description": "Support uplift/downlift, event windows, and affected products/locations."\n                    },\n                    {\n                      "title": "Implement scenario run and storage",\n                      "description": "Persist scenario definitions and outputs separately from baseline."\n                    },\n                    {\n                      "title": "Implement KPI delta calculations",\n                      "description": "Compute differences between scenario and baseline KPIs."\n                    },\n                    {\n                      "title": "Create scenario comparison view",\n                      "description": "Provide side-by-side baseline vs scenario KPI comparison for decision-making."\n                    }\n                  ],\n                  "traceability": [\n                    {\n                      "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n                      "evidenceSnippet": "Tool shall provide scenario simulation (e.g., demand surge, supply disruption)."\n                    }\n                  ]\n                },\n                {\n                  "title": "Create a supply disruption scenario and simulate impacts",\n                  "description": "As a supply planning manager,\\nI want to simulate supply disruption scenarios,\\nso that I can proactively assess mitigation actions to protect customer service.",\n                  "acceptanceCriteria": [\n                    "Given supply constraints are specified When I run the scenario Then projected shortages and service level impacts are calculated",\n                    "Given multiple mitigation options exist When I adjust inventory policies or prioritization assumptions Then the scenario re-computes projected KPIs",\n                    "Given scenarios are saved When I revisit them Then I can see assumptions, timestamps, and results"\n                  ],\n                  "tasks": [\n                    {\n                      "title": "Define disruption constraint inputs",\n                      "description": "Support lead time increases, capacity reductions, and supply delays."\n                    },\n                    {\n                      "title": "Implement shortage and service impact calculations",\n                      "description": "Calculate stockout risk/service level impacts under constraints."\n                    },\n                    {\n                      "title": "Enable iterative scenario re-runs",\n                      "description": "Allow users to change assumptions and re-run with version tracking."\n                    }\n                  ],\n                  "traceability": [\n                    {\n                      "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n                      "evidenceSnippet": "Scenario planning and simulation capabilities... supply disruption."\n                    }\n                  ]\n                }\n              ],\n              "traceability": [\n                {\n                  "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n                  "evidenceSnippet": "Increase planner productivity through automation and scenario modeling."\n                }\n              ]\n            },\n            {\n              "title": "Scenario governance and sharing",\n              "description": "Enable controlled sharing, approval, and reuse of scenarios across planning teams.",\n              "userStories": [\n                {\n                  "title": "Share scenarios with stakeholders for review",\n                  "description": "As a demand planning lead,\\nI want to share scenario results with stakeholders,\\nso that cross-functional teams can align on the best course of action.",\n                  "acceptanceCriteria": [\n                    "Given a scenario exists When I share it with named stakeholders Then they can access the scenario results according to their role permissions",\n                    "Given a scenario is updated When stakeholders view it Then they can see the latest version and a change history",\n                    "Given approvals are required When a scenario is marked for decision Then an approval status is captured"\n                  ],\n                  "tasks": [\n                    {\n                      "title": "Implement scenario access controls",\n                      "description": "Apply RBAC to scenario view/edit/share actions."\n                    },\n                    {\n                      "title": "Implement scenario version history",\n                      "description": "Track changes to assumptions and results over time."\n                    },\n                    {\n                      "title": "Implement lightweight approval capture",\n                      "description": "Record decision/approval status and approver identity."\n                    }\n                  ],\n                  "traceability": [\n                    {\n                      "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n                      "evidenceSnippet": "Scenario planning and simulation capabilities."\n                    }\n                  ]\n                }\n              ],\n              "traceability": [\n                {\n                  "sourceDocumentId": "Supply_Chain_Demand_Forecasting_Inventory_Optimization_BPD.pdf",\n                  "evidenceSnippet": "In Scope: Scenario planning and simulation capabilities."\n                }\n              ]\n            },\n            {\n              "title": "Performance Monitoring, Dashboards & KPI Visibility",\n              "description": "Deliver executive and operational dashboards providing real-time (daily minimum; hourly preferred) visibility into demand, supply, and inventory KPIs such as forecast accuracy, service level, inventory turns, DOH, stockout rate, and working capital. This epic supports ongoing performance monitoring and decision-making.",\n              "features": [\n                {\n                  "title": "Executive and operational KPI dashboards",\n                  "description": "Provide dashboards that display core KPIs and trends for executives and operations, enabling monitoring of outcomes tied to business objectives.",\n                  "userStories": [\n                    {\n                      